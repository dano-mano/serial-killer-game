# =============================================================================
# Environment Configuration
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_* variables are embedded in the client bundle at build time.
# Never put secrets in NEXT_PUBLIC_* variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Required
# Find these in your Supabase project: Settings > API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER put this in a NEXT_PUBLIC_* variable.
# Used only in server-side code (DAL, Server Actions).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Sentry — Required
# Find the DSN in your Sentry project: Settings > Client Keys (DSN)
# SENTRY_AUTH_TOKEN is only needed in CI for source map upload.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id

# Used by @sentry/nextjs during build to upload source maps to Sentry.
# Only required in CI. Set as a GitHub Actions secret (SENTRY_AUTH_TOKEN).
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# -----------------------------------------------------------------------------
# PostHog Analytics — Optional
# Find these in your PostHog project: Settings > Project > Project API Key
# Leave empty to disable analytics.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# -----------------------------------------------------------------------------
# Azure Blob Storage — Optional
# Used for serving large game assets (sprite atlases, audio files).
# Leave empty if not using Azure Blob Storage.
# -----------------------------------------------------------------------------
# AZURE_BLOB_STORAGE_URL=https://your-account.blob.core.windows.net/your-container

# -----------------------------------------------------------------------------
# Logging — Optional
# Controls Pino log level. Defaults to 'info' in production, 'debug' in development.
# Valid values: trace, debug, info, warn, error, fatal
# -----------------------------------------------------------------------------
# LOG_LEVEL=info
